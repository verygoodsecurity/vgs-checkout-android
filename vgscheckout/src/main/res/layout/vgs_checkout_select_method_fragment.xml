<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="always"
        android:paddingBottom="@dimen/vgs_checkout_payment_methods_bottom_padding"
        android:paddingTop="@dimen/vgs_checkout_margin_padding_size_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/llAlternativePaymentMethod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="visible"
                android:orientation="vertical"
                android:paddingStart="@dimen/vgs_checkout_margin_padding_size_medium"
                android:paddingBottom="@dimen/vgs_checkout_margin_padding_size_medium"
                android:paddingEnd="@dimen/vgs_checkout_margin_padding_size_medium">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/vgs_checkout_margin_padding_size_medium"
                    android:text="Select Payment Method"
                    android:textAppearance="?attr/textAppearanceHeadline6" />

                <include layout="@layout/vgs_checkout_google_pay_button" />

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/vgs_checkout_margin_padding_size_medium"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="@dimen/vgs_checkout_default_divider_size"
                        android:layout_weight="1"
                        android:background="@color/vgs_checkout_nobel" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/vgs_checkout_margin_padding_size_medium"
                        android:layout_marginEnd="@dimen/vgs_checkout_margin_padding_size_medium"
                        android:text="Or"
                        android:textAppearance="?attr/textAppearanceSubtitle1"
                        android:textColor="@color/vgs_checkout_nobel" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="@dimen/vgs_checkout_default_divider_size"
                        android:layout_weight="1"
                        android:background="@color/vgs_checkout_nobel" />
                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.appcompat.widget.LinearLayoutCompat>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPaymentMethods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.core.widget.NestedScrollView>

    <View
        android:id="@+id/viewOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.5"
        android:background="?android:attr/windowBackground"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/vgs_checkout_payment_methods_bottom_gradient"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/mbPresent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/mbPresent"
        style="@style/VGSCheckout.PrimaryButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/vgs_checkout_margin_padding_size_medium"
        android:layout_marginEnd="@dimen/vgs_checkout_margin_padding_size_medium"
        android:layout_marginBottom="@dimen/vgs_checkout_margin_padding_size_xxmedium"
        android:maxHeight="@dimen/vgs_checkout_button_height"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="Pay $1" />
</androidx.constraintlayout.widget.ConstraintLayout>